# E-mail quando alguém clica no checkout (Nodemailer com Gmail)
# Copie este arquivo para .env e preencha com seus dados.

# E-mail Gmail que vai ENVIAR (e receber as notificações)
EMAIL_USER=jeffersonalionco@gmail.com

# Senha de app do Gmail (não use a senha normal da conta)
# Como criar: Conta Google → Segurança → Verificação em 2 etapas (ativar) → Senhas de app → Gerar
EMAIL_PASS=

# Opcional: e-mail que recebe os avisos (padrão: jeffersonalionco@gmail.com)
# EMAIL_TO=jeffersonalionco@gmail.com
